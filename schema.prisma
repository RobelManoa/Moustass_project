datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  role         Role     @default(USER)

  createdAt    DateTime @default(now())

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  keys             Key[]
  audits           Audit[]
}

model Message {
  id              String   @id @default(uuid())

  senderId        String
  recipientId     String

  mediaUrl        String
  mediaSha256     String
  mediaSignature  String
  signatureAlg    String   @default("PS256")
  signerKid       String

  manifestJson    Json

  createdAt       DateTime @default(now())
  expiresAt       DateTime?

  sender     User @relation("SentMessages", fields: [senderId], references: [id])
  recipient  User @relation("ReceivedMessages", fields: [recipientId], references: [id])

  @@index([senderId])
  @@index([recipientId])
}

model Audit {
  id         String   @id @default(uuid())

  actorId    String
  action     String
  targetType String
  targetId   String

  ipAddress  String?
  signature  String?

  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])
}

model Key {
  id         String   @id @default(uuid())

  userId     String
  publicKey  String
  keySize    Int
  status     String   // active, revoked

  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model License {
  id            String   @id @default(uuid())

  clientName    String
  logoUrl       String?
  email         String
  phone         String?

  serialNumber  String   @unique
  maxUsers      Int

  createdAt     DateTime @default(now())
  expiresAt     DateTime
}