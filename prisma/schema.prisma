generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id          String        @id @default(uuid())
  email       String        @unique
  passwordHash String
  name        String?
  role        Role          @default(USER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  videoMessages VideoMessage[]
  audits        Audit[]

  @@map("users")
}

model VideoMessage {
  id                String   @id @default(uuid())
  ownerId           String
  title             String
  description       String?
  originalFileName  String
  mimeType          String
  storagePath       String
  mediaSha256       String
  mediaSignature    String
  manifestJson      Json
  deletedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([mediaSha256])
  @@map("video_messages")
}

model Audit {
  id          String   @id @default(uuid())
  actorId     String  
  action      String   
  resource    String   
  resourceId  String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([resource])
  @@map("audits")
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

model License {
  id           String         @id @default(uuid())
  clientName   String         @unique
  serialNumber String         @unique 
  email        String?
  phone        String?
  logoUrl      String?
  status       LicenseStatus  @default(ACTIVE)
  expiresAt    DateTime?
  maxUsers     Int?
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("licenses")
}

// Table pour les clés cryptographiques
model CryptoKey {
  id          String    @id @default(uuid())
  keyType     String    // PRIVATE, PUBLIC, etc.
  keyValue    String    // PEM format
  description String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@unique([keyType])
  @@map("crypto_keys")
}